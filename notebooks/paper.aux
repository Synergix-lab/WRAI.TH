\@writefile{toc}{\contentsline {section}{\numberline {10}Experiments}{13}{section.10}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {10.1}Experiment 1: Threats Without Protection}{13}{subsection.10.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {9}{\ignorespaces Four threats without protection mechanisms. Top-left: LLM noise inflates $|M_t|$ while signal/noise ratio drops. Top-right: boot cost grows unboundedly vs. bounded by $B_{\max }$. Bottom-left: conflict probability $P(\text  {conflict}) = 1-(1-0.3)^N$ reaches 97\% at $N=10$. Bottom-right: inbox size grows infinitely without TTL.}}{13}{figure.caption.26}\protected@file@percent }
\newlabel{fig:threats}{{9}{13}{Four threats without protection mechanisms. Top-left: LLM noise inflates $|M_t|$ while signal/noise ratio drops. Top-right: boot cost grows unboundedly vs. bounded by $B_{\max }$. Bottom-left: conflict probability $P(\text {conflict}) = 1-(1-0.3)^N$ reaches 97\% at $N=10$. Bottom-right: inbox size grows infinitely without TTL}{figure.caption.26}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {10.2}Experiment 2: Temporal Mechanisms}{13}{subsection.10.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {10}{\ignorespaces Temporal mechanisms over 24 hours (6 agents, production rates). (a) Message TTL: cumulative sends grow linearly while live messages stay bounded. (b) Agent staleness: 30min heartbeat timeout across 6 agents. (c) ACK escalation: 15min $\to $ notify, 45min $\to $ escalate. (d) File locks: TTL 30min, auto-release on crash.}}{14}{figure.caption.27}\protected@file@percent }
\newlabel{fig:temporal}{{10}{14}{Temporal mechanisms over 24 hours (6 agents, production rates). (a) Message TTL: cumulative sends grow linearly while live messages stay bounded. (b) Agent staleness: 30min heartbeat timeout across 6 agents. (c) ACK escalation: 15min $\to $ notify, 45min $\to $ escalate. (d) File locks: TTL 30min, auto-release on crash}{figure.caption.27}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {10.3}Experiment 3: Multi-Agent Conflict \& Resolution}{14}{subsection.10.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {11}{\ignorespaces Multi-agent conflict dynamics (6 agents, 67 memories, 1.5\% base rate). (a) Active conflicts remain bounded via CTO resolution. (b) Write events per agent: gray dots show redundant writes ($\sim $60\%). (c) Conflict rate scaling: quadratic $P \propto N(N-1)$, with production point at $N=6$.}}{14}{figure.caption.28}\protected@file@percent }
\newlabel{fig:conflicts}{{11}{14}{Multi-agent conflict dynamics (6 agents, 67 memories, 1.5\% base rate). (a) Active conflicts remain bounded via CTO resolution. (b) Write events per agent: gray dots show redundant writes ($\sim $60\%). (c) Conflict rate scaling: quadratic $P \propto N(N-1)$, with production point at $N=6$}{figure.caption.28}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {10.4}Experiment 4: Knowledge Convergence}{15}{subsection.10.4}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {12}{\ignorespaces Knowledge convergence dynamics. (a) Cumulative knowledge follows logarithmic growth, reaching 80\% of the domain by spawn 30. (b) Marginal learning rate decays rapidly after the exploration phase. (c) Write redundancy rises to $\sim $60\%, matching production measurements.}}{15}{figure.caption.29}\protected@file@percent }
\newlabel{fig:convergence}{{12}{15}{Knowledge convergence dynamics. (a) Cumulative knowledge follows logarithmic growth, reaching 80\% of the domain by spawn 30. (b) Marginal learning rate decays rapidly after the exploration phase. (c) Write redundancy rises to $\sim $60\%, matching production measurements}{figure.caption.29}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {10.5}Experiment 5: Cost Scaling}{15}{subsection.10.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {13}{\ignorespaces Cost scaling with shared memory. (a) Total daily cost: naive grows linearly at \$78/agent/day; shared memory achieves sub-linear growth. (b) Per-agent cost decreases with team size. (c) Boot-to-work ratio shrinks as shared knowledge reduces per-agent discovery overhead.}}{15}{figure.caption.30}\protected@file@percent }
\newlabel{fig:scaling}{{13}{15}{Cost scaling with shared memory. (a) Total daily cost: naive grows linearly at \$78/agent/day; shared memory achieves sub-linear growth. (b) Per-agent cost decreases with team size. (c) Boot-to-work ratio shrinks as shared knowledge reduces per-agent discovery overhead}{figure.caption.30}{}}
